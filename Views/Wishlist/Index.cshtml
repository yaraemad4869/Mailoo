@model IEnumerable<Product>

@{
    ViewData["Title"] = "Index";
}


<div class="container">
    <div class="row justify-content-center">
        @foreach (var item in Model)
        {
             @if (item.Quantity > 0)
            {

                <div class="col-md-4 col-sm-6 d-flex justify-content-center">
                    <div class="card" style="width: 18rem;">
                        <img src="@item.imageSrc" class="card-img-top" alt="Product Image">
                        <div class="card-body">
                            <h5 class="card-title">@item.Name</h5>
                            <p class="card-text">@item.Description</p>
                            <p>Price @item.Price</p>

                            <a href="#" class="btn btn-primary" asp-action="New" asp-controller="Cart">Add to cart</a>
                            
                            <a asp-controller="Wishlist" asp-action="Delete" asp-route-Id="@item.ID" class="btn btn-primary btn-sm btn-danger">
                                <i class="bi bi-trash3"></i> Delete
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>